// DRAWING
// ═══════════════════════════════════════════
function drawFrame(){
  tick++;
  animT = Math.min(1, animT + .018);
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#F5EDD8'; ctx.fillRect(0,0,W,H);

  // Paper grain overlay on canvas
  ctx.fillStyle = 'rgba(26,16,8,.012)';
  for(let x=0;x<W;x+=18) for(let y=0;y<H;y+=18)
    if(Math.random()<.08) ctx.fillRect(x+Math.random()*5-2,y+Math.random()*5-2,1.5,1.5);

  // Coordinate axes for Lorenz curve
  const pad = {l:80, r:60, t:50, b:80};
  const cw2 = W-pad.l-pad.r, ch2 = H-pad.t-pad.b;

  // ── LORENZ CURVE ──
  drawLorenz(pad, cw2, ch2);

  // ── WEALTH PYRAMID (right side) ──
  drawPyramid(pad, cw2, ch2);

  // ── ASSET BREAKDOWN ARC (center) ──
  drawDonut(pad, cw2, ch2);

  requestAnimationFrame(drawFrame);
}

function drawLorenz(pad, cw2, ch2){
  const lx = pad.l, ly = pad.t;
  const lw = cw2*.44, lh = ch2;

  // Grid
  for(let i=0;i<=4;i++){
    const x = lx+lw*i/4, y2 = ly+lh*i/4;
    ctx.strokeStyle='rgba(26,16,8,.06)'; ctx.lineWidth=.5;
    ctx.beginPath(); ctx.moveTo(lx,y2); ctx.lineTo(lx+lw,y2); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x,ly); ctx.lineTo(x,ly+lh); ctx.stroke();
    ctx.save();
    ctx.font='400 8px "Josefin Sans",sans-serif';
    ctx.fillStyle='rgba(26,16,8,.35)'; ctx.textAlign='right';
    ctx.fillText((100-i*25)+'%', lx-5, ly+lh*i/4+3);
    ctx.textAlign='center';
    ctx.fillText((i*25)+'%', lx+lw*i/4, ly+lh+15);
    ctx.restore();
  }

  // Axes labels
  ctx.save();
  ctx.font='500 8px "Josefin Sans",sans-serif';
  ctx.fillStyle='rgba(26,16,8,.45)';
  ctx.textAlign='center'; ctx.textBaseline='bottom';
  ctx.fillText('% Dân số (từ nghèo → giàu)', lx+lw/2, ly+lh+35);
  ctx.translate(lx-45, ly+lh/2);
  ctx.rotate(-Math.PI/2);
  ctx.fillText('% Của cải (tích lũy)', 0, 0);
  ctx.restore();

  // Equality line
  ctx.strokeStyle='rgba(26,16,8,.15)'; ctx.lineWidth=1;
  ctx.setLineDash([6,6]);
  ctx.beginPath(); ctx.moveTo(lx,ly+lh); ctx.lineTo(lx+lw,ly); ctx.stroke();
  ctx.setLineDash([]);
  ctx.save(); ctx.font='italic 9px "Noto Serif",serif'; ctx.fillStyle='rgba(26,16,8,.25)';
  ctx.textAlign='center';
  ctx.fillText('Bình đẳng tuyệt đối', lx+lw*.55, ly+lh*.38);
  ctx.restore();

  // Actual Lorenz curve
  ctx.beginPath();
  LORENZ.forEach((pt,i) => {
    const x = lx + lw*(pt.pct/100);
    const y = ly + lh*(1-pt.wealth/100);
    if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
  });
  ctx.strokeStyle='rgba(139,32,16,.7)'; ctx.lineWidth=2;
  ctx.stroke();

  // Fill area
  ctx.beginPath();
  ctx.moveTo(lx,ly+lh);
  LORENZ.forEach(pt => {
    const x = lx + lw*(pt.pct/100);
    const y = ly + lh*(1-pt.wealth/100);
    ctx.lineTo(x,y);
  });
  ctx.closePath();
  ctx.fillStyle='rgba(139,32,16,.06)'; ctx.fill();

  // Gini label
  ctx.save();
  ctx.font='700 11px "Josefin Sans",sans-serif'; ctx.fillStyle=colors.rust;
  ctx.textAlign='left';
  ctx.fillText('Gini = 0.38', lx+lw*.15, ly+lh*.65);
  ctx.font='italic 9px "Noto Serif",serif'; ctx.fillStyle='rgba(26,16,8,.4)';
  ctx.fillText('(Diện tích giữa 2 đường)', lx+lw*.15, ly+lh*.75);
  ctx.restore();

  // Title
  ctx.save();
  ctx.font='700 11px "Josefin Sans",sans-serif'; ctx.fillStyle='rgba(26,16,8,.6)';
  ctx.textAlign='left'; ctx.letterSpacing='.1em';
  ctx.fillText('ĐƯỜNG LORENZ', lx, ly-12);
  ctx.restore();

  // Annotation points
  const annotations = [
    {idx:5, label:'Top 40% sở hữu 85%'},
    {idx:9, label:'Top 10% sở hữu 43%'},
  ];
  annotations.forEach(a => {
    const pt = LORENZ[a.idx];
    const x = lx + lw*(pt.pct/100), y = ly + lh*(1-pt.wealth/100);
    ctx.beginPath(); ctx.arc(x,y,4,0,Math.PI*2);
    ctx.fillStyle=colors.rust2; ctx.fill();
    ctx.save(); ctx.font='italic 8.5px "Noto Serif",serif'; ctx.fillStyle='rgba(139,32,16,.8)';
    ctx.textAlign='left'; ctx.shadowColor='rgba(245,237,216,.9)'; ctx.shadowBlur=4;
    ctx.fillText(a.label, x+8, y-3);
    ctx.restore();
  });
}

const colors={rust:'#8B2010',rust2:'#B03018',indigo:'#1A2870',jade:'#1A5030',gold:'#8B6010',br:'#6A4A20',dark:'#4A3010',fdi:'#1A1A8B'};

function drawPyramid(pad, cw2, ch2){
  const px = pad.l + cw2*.46 + 20;
  const pw = cw2*.26;
  const ph = ch2;
  const py = pad.t;

  ctx.save();
  ctx.font='700 11px "Josefin Sans",sans-serif'; ctx.fillStyle='rgba(26,16,8,.55)';
  ctx.textAlign='left'; ctx.textBaseline='top';
  ctx.fillText('THÁP TÀI SẢN', px, py-12);
  ctx.restore();

  const segs = [...SEGMENTS].reverse();
  const total = segs.reduce((s,g)=>s+g.pct,0);
  let yOff = 0;

  segs.forEach((seg,i) => {
    const segH = (seg.pct/total)*ph * animT;
    const frac = yOff/ph;
    const widthAtBottom = pw;
    const widthAtTop = pw * (1-frac*.7);
    const widthAtEnd = pw * (1-(yOff+segH)/ph*.7);
    const xCenter = px + pw/2;

    const x0 = xCenter - widthAtBottom/2, x1 = xCenter + widthAtBottom/2;
    const xT0 = xCenter - widthAtEnd/2, xT1 = xCenter + widthAtEnd/2;
    const y0 = py+ph-yOff, y1 = py+ph-yOff-segH;

    const isH = hovSeg && hovSeg.id===seg.id;

    // Fill
    ctx.beginPath();
    ctx.moveTo(x0,y0); ctx.lineTo(x1,y0);
    ctx.lineTo(xT1,y1); ctx.lineTo(xT0,y1);
    ctx.closePath();
    ctx.fillStyle = isH ? seg.colLight+'CC' : seg.col+'99';
    ctx.fill();
    ctx.strokeStyle = seg.colLight+'BB'; ctx.lineWidth=isH?1.5:.6;
    ctx.stroke();

    // Hatching pattern (woodblock effect)
    if(segH > 20){
      ctx.save();
      ctx.clip();
      for(let y=y0;y>y1;y-=8){
        ctx.beginPath();
        ctx.moveTo(xT0,y); ctx.lineTo(xT1,y);
        ctx.strokeStyle=`rgba(255,255,255,.08)`; ctx.lineWidth=.5; ctx.stroke();
      }
      ctx.restore();
    }

    // Label
    if(segH > 18){
      ctx.save();
      const midY = (y0+y1)/2;
      ctx.font=`600 ${Math.min(9,Math.max(7,segH/6))}px "Josefin Sans",sans-serif`;
      ctx.fillStyle=`rgba(255,255,255,.85)`;
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.shadowColor='rgba(0,0,0,.4)'; ctx.shadowBlur=4;
      ctx.fillText(seg.pct+'%', xCenter, midY);
      if(segH > 28){
        ctx.font=`400 ${Math.min(8,segH/7)}px "Josefin Sans",sans-serif`;
        ctx.fillStyle='rgba(255,255,255,.55)';
        ctx.fillText(seg.label.slice(0,18), xCenter, midY+11);
      }
      ctx.restore();
    }

    // Right connector label
    if(segH > 14){
      const midY = (y0+y1)/2;
      ctx.save();
      ctx.font=`500 8px "Josefin Sans",sans-serif`;
      ctx.fillStyle=`rgba(${hexRgbSimple(seg.col).join(',')},0.7)`;
      ctx.textAlign='left'; ctx.textBaseline='middle';
      ctx.fillText(`$${seg.valB}B`, xCenter+widthAtBottom/2+8, midY);
      ctx.restore();
    }

    yOff += segH;
  });

  // Pyramid base label
  ctx.save();
  ctx.font='italic 9px "Noto Serif",serif'; ctx.fillStyle='rgba(26,16,8,.35)';
  ctx.textAlign='center'; ctx.textBaseline='top';
  ctx.fillText('96 triệu dân', px+pw/2, py+ph+8);
  ctx.restore();
}

function drawDonut(pad, cw2, ch2){
  const dx = pad.l + cw2*.72+20;
  const dy = pad.t + ch2/2;
  const dr = Math.min(cw2*.15, ch2*.42);
  const segments = SEGMENTS;

  ctx.save();
  ctx.font='700 11px "Josefin Sans",sans-serif'; ctx.fillStyle='rgba(26,16,8,.55)';
  ctx.textAlign='center'; ctx.textBaseline='bottom';
  ctx.fillText('PHÂN BỔ TÀI SẢN', dx, pad.t-12);
  ctx.restore();

  let angleStart = -Math.PI/2;
  const total = segments.reduce((s,g)=>s+g.pct,0);

  segments.forEach(seg => {
    const angle = (seg.pct/total)*Math.PI*2 * animT;
    const isH = hovSeg && hovSeg.id===seg.id;
    const innerR = dr*.55, outerR = dr*(isH?1.05:1);

    ctx.beginPath();
    ctx.arc(dx,dy,outerR,angleStart,angleStart+angle);
    ctx.arc(dx,dy,innerR,angleStart+angle,angleStart,true);
    ctx.closePath();
    ctx.fillStyle = isH ? seg.colLight+'DD' : seg.col+'AA';
    ctx.fill();
    ctx.strokeStyle='rgba(245,237,216,.8)'; ctx.lineWidth=isH?2:1;
    ctx.stroke();

    // Outer tick
    const midA = angleStart + angle/2;
    const tx1=Math.cos(midA)*(outerR+3)+dx, ty1=Math.sin(midA)*(outerR+3)+dy;
    const tx2=Math.cos(midA)*(outerR+9)+dx, ty2=Math.sin(midA)*(outerR+9)+dy;
    ctx.beginPath(); ctx.moveTo(tx1,ty1); ctx.lineTo(tx2,ty2);
    ctx.strokeStyle=seg.col+'88'; ctx.lineWidth=1.2; ctx.stroke();

    // Label outside
    if(angle > .3){
      const lx=Math.cos(midA)*(outerR+20)+dx, ly2=Math.sin(midA)*(outerR+20)+dy;
      ctx.save();
      ctx.font=`500 8px "Josefin Sans",sans-serif`;
      ctx.fillStyle=seg.col;
      ctx.textAlign=Math.cos(midA)>0?'left':'right'; ctx.textBaseline='middle';
      ctx.shadowColor='rgba(245,237,216,.9)'; ctx.shadowBlur=5;
      ctx.fillText(seg.pct+'%', lx, ly2);
      ctx.restore();
    }

    angleStart += angle;
  });

  // Center text
  ctx.save();
  ctx.font='700 14px "Josefin Sans",sans-serif'; ctx.fillStyle='rgba(26,16,8,.7)';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText('$1,040B', dx, dy-8);
  ctx.font='italic 9px "Noto Serif",serif'; ctx.fillStyle='rgba(26,16,8,.35)';
  ctx.fillText('Tổng tài sản', dx, dy+8);
  ctx.restore();

  // Legend below donut
  const legX = dx - dr*.8, legY = dy + dr + 20;
  segments.forEach((seg,i) => {
    const row = Math.floor(i/2), col2 = i%2;
    const x = legX + col2*(dr*1.05);
    const y = legY + row*16;
    ctx.save();
    ctx.fillStyle=seg.col; ctx.fillRect(x,y,10,8);
    ctx.font='400 7.5px "Josefin Sans",sans-serif'; ctx.fillStyle='rgba(26,16,8,.5)';
    ctx.textAlign='left'; ctx.textBaseline='middle';
    ctx.fillText(seg.label.slice(0,16), x+13, y+4);
    ctx.restore();
  });
}

function hexRgbSimple(h){
  if(!h||h.length<7) return [100,100,100];
  return [parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];
}

// ── INTERACTION ──
cvs.addEventListener('mousemove', e => {
  const rc=cvs.getBoundingClientRect();
  const sx=e.clientX-rc.left, sy=e.clientY-rc.top;
  const pad={l:80,r:60,t:50,b:80};
  const cw2=W-pad.l-pad.r, ch2=H-pad.t-pad.b;
  const dx=pad.l+cw2*.72+20, dy=pad.t+ch2/2, dr=Math.min(cw2*.15,ch2*.42);
  const dist=Math.sqrt((sx-dx)**2+(sy-dy)**2);

  let found=null;
  if(dist<dr && dist>dr*.55){
    let ang=Math.atan2(sy-dy,sx-dx)+Math.PI/2;
    if(ang<0) ang+=Math.PI*2;
    let acc=0;
    const total=SEGMENTS.reduce((s,g)=>s+g.pct,0);
    for(const seg of SEGMENTS){
      acc+=(seg.pct/total)*Math.PI*2;
      if(ang<acc){found=seg;break;}
    }
  }
  // Pyramid hit test
  if(!found){
    const px=pad.l+cw2*.46+20, pw=cw2*.26, ph=ch2, py=pad.t;
    const total=SEGMENTS.reduce((s,g)=>s+g.pct,0);
    let yOff=0;
    const segs=[...SEGMENTS].reverse();
    for(const seg of segs){
      const segH=(seg.pct/total)*ph;
      const y1=py+ph-yOff, y2=py+ph-yOff-segH;
      if(sy>=y2&&sy<=y1&&sx>=px&&sx<=px+pw){found=seg;break;}
      yOff+=segH;
    }
  }

  hovSeg=found;
  cvs.style.cursor=found?'pointer':'default';
  const tip=document.getElementById('tip');
  if(found){
    tip.style.display='block';
    tip.style.borderLeftColor=found.rust2||found.col;
    const ox=e.clientX>window.innerWidth*.6?e.clientX-330:e.clientX+16;
    tip.style.left=ox+'px'; tip.style.top=Math.max(60,e.clientY-90)+'px';
    document.getElementById('tb').textContent=found.badge;
    document.getElementById('tn').textContent=found.label; document.getElementById('tn').style.color=found.colLight;
    document.getElementById('tp').textContent=found.pct+'% tài sản quốc gia (~$'+found.valB+'B)';
    document.getElementById('tp').style.color=found.colLight;
    document.getElementById('td').textContent=found.desc;
    document.getElementById('ts').innerHTML=(found.subs||[]).map(s=>`<div class="tts"><div class="ttsv">${s.val}</div><div class="ttsk">${s.name}</div></div>`).join('');
  } else tip.style.display='none';
});

